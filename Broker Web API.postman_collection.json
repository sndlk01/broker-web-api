    {
      "name": "Brokers",
      "item": [
        {
          "name": "Get All Brokers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/brokers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "brokers"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "cfd",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Broker by Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/brokers/:slug",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "brokers",
                ":slug"
              ],
              "variable": [
                {
                  "key": "slug"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Broker",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Example Broker\",\n  \"slug\": \"example-broker\",\n  \"description\": \"A sample broker\",\n  \"logo_url\": \"https://example.com/logo.png\",\n  \"website\": \"https://example.com\",\n  \"broker_type\": \"cfd\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/brokers",
              "host": ["{{baseUrl}}"],
              "path": ["brokers"]
            }
          },
          "response": []
        },
        {
          "name": "Update Broker",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Broker Name\",\n  \"description\": \"Updated description\",\n  \"logo_url\": \"https://example.com/new-logo.png\",\n  \"website\": \"https://example.com\",\n  \"broker_type\": \"stock\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/brokers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["brokers", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          },
          "response": []
        },
        {
          "name": "Delete Broker",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/brokers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["brokers", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          },
          "response": []
        }
      ]
    }
  ],
